generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  country       String    @default("International")
  role          String    @default("User")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  usageLogs     UsageLog[]
  alertEvents   AlertEvent[]
  preferences   UserPreference?
  contactInquiries ContactInquiry[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  planType        String
  billingCycle    String   @default("monthly")
  price           Float
  currency        String
  startDate       DateTime @default(now())
  expiryDate      DateTime
  paymentProvider String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  featureName String
  usageType   String   @default("request")
  timestamp   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, featureName, timestamp])
}

model AlertEvent {
  id         String   @id @default(cuid())
  userId     String?
  fingerprint String  @unique
  alertType  String
  severity   String   @default("info")
  pair       String?
  timeframe  String?
  title      String
  message    String
  status     String   @default("active")
  source     String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([alertType, createdAt])
}

model UserPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  emailAlerts      Boolean  @default(true)
  pushAlerts       Boolean  @default(false)
  telegramAlerts   Boolean  @default(true)
  soundAlerts      Boolean  @default(true)
  riskPerTrade     Float    @default(1.0)
  defaultTimeframe String   @default("H1")
  minProbability   Int      @default(75)
  autoScan         Boolean  @default(true)
  pairMajors       Boolean  @default(true)
  pairCrosses      Boolean  @default(true)
  pairExotics      Boolean  @default(false)
  pairCrypto       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformSetting {
  key       String @id
  value     String
  updatedAt DateTime @updatedAt
}

model UsageLimit {
  id          String  @id @default(cuid())
  planName    String
  featureName String
  hourlyLimit String
  dailyLimit  String

  @@unique([planName, featureName])
}

model ContactInquiry {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  email           String
  phone           String?
  company         String?
  country         String?
  inquiryType     String
  subject         String
  message         String
  status          String   @default("New")
  adminNotifiedAt DateTime?
  thankYouSentAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}
