generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  country       String    @default("International")
  role          String    @default("User")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  subscriptions      Subscription[]
  usageLogs          UsageLog[]
  enrollment         CourseEnrollment?
  lessonProgress     LessonProgress[]
  contactInquiries   ContactInquiry[]
  preference         UserPreference?
  learningEvents     LearningEvent[]
  tradeSignals       TradeSignal[]
  tradePlans         TradePlan[]
  tradeExecutions    TradeExecution[]
  positions          Position[]
  journalEntries     JournalEntry[]
}

enum AssetClass {
  FOREX
  CRYPTO
  COMMODITY
  INDEX
  EQUITY
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeSignalStatus {
  OPEN
  TRIGGERED
  INVALIDATED
  EXPIRED
}

enum TradePlanStatus {
  DRAFT
  ACTIVE
  CANCELLED
  EXECUTED
}

enum ExecutionStatus {
  PENDING
  OPEN
  CLOSED
  CANCELLED
}

enum PositionStatus {
  OPEN
  CLOSED
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  planType        String
  billingCycle    String   @default("monthly")
  price           Float
  currency        String
  startDate       DateTime @default(now())
  expiryDate      DateTime
  paymentProvider String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  featureName String
  usageType   String   @default("request")
  timestamp   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, featureName, timestamp])
}

model CourseEnrollment {
  id           String    @id @default(cuid())
  userId       String    @unique
  enrolledAt   DateTime  @default(now())
  lastAccessAt DateTime  @updatedAt
  completedAt  DateTime?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress LessonProgress[] @relation("EnrollmentProgress")
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonSlug  String
  /// not_started | started | completed
  status      String    @default("not_started")
  startedAt   DateTime?
  completedAt DateTime?

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment CourseEnrollment @relation("EnrollmentProgress", fields: [userId], references: [userId], map: "LessonProgress_enrollmentUserId_fkey")

  @@unique([userId, lessonSlug])
  @@index([userId])
}

model PlatformSetting {
  key       String @id
  value     String
  updatedAt DateTime @updatedAt
}

model UsageLimit {
  id          String  @id @default(cuid())
  planName    String
  featureName String
  hourlyLimit String
  dailyLimit  String

  @@unique([planName, featureName])
}

model UserPreference {
  id               String   @id @default(uuid())
  userId           String   @unique
  emailAlerts      Boolean  @default(true)
  pushAlerts       Boolean  @default(false)
  telegramAlerts   Boolean  @default(true)
  soundAlerts      Boolean  @default(true)
  riskPerTrade     Float    @default(1.0)
  defaultTimeframe String   @default("H1")
  minProbability   Int      @default(75)
  autoScan         Boolean  @default(true)
  pairMajors       Boolean  @default(true)
  pairCrosses      Boolean  @default(true)
  pairExotics      Boolean  @default(false)
  pairCrypto       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactInquiry {
  id          String    @id @default(cuid())
  userId      String?
  name        String
  email       String
  phone       String?
  company     String?
  country     String?
  inquiryType String
  subject     String
  message     String
  status      String    @default("Received")
  thankYouSentAt DateTime?
  adminNotifiedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, status])
}

model LearningEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  route      String
  lessonSlug String?
  week       Int?
  day        String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}

model Asset {
  id            String           @id @default(cuid())
  symbol        String           @unique
  name          String
  assetClass    AssetClass
  baseCurrency  String?
  quoteCurrency String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  candles       MarketCandle[]
  signals       TradeSignal[]
  plans         TradePlan[]
  executions    TradeExecution[]
  positions     Position[]
}

model MarketCandle {
  id         String   @id @default(cuid())
  assetId    String
  timeframe  String
  open       Float
  high       Float
  low        Float
  close      Float
  volume     Float?
  timestamp  DateTime
  createdAt  DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, timeframe, timestamp])
  @@index([assetId, timeframe, timestamp])
}

model TradeSignal {
  id            String            @id @default(cuid())
  userId        String?
  assetId       String
  timeframe     String
  direction     TradeDirection
  confidence    Int
  source        String
  status        TradeSignalStatus @default(OPEN)
  entryPrice    Float?
  stopLoss      Float?
  takeProfit    Float?
  rationale     Json?
  createdAt     DateTime          @default(now())
  resolvedAt    DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  executions TradeExecution[]

  @@index([assetId, timeframe, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model TradePlan {
  id             String          @id @default(cuid())
  userId         String
  assetId        String
  timeframe      String
  direction      TradeDirection
  riskPercent    Float
  entryPrice     Float
  stopLoss       Float
  takeProfit     Float
  notes          String?
  status         TradePlanStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  executions TradeExecution[]

  @@index([userId, status, createdAt])
  @@index([assetId, createdAt])
}

model TradeExecution {
  id              String          @id @default(cuid())
  userId          String
  assetId         String
  signalId        String?
  planId          String?
  direction       TradeDirection
  status          ExecutionStatus @default(PENDING)
  quantity        Float
  openPrice       Float?
  closePrice      Float?
  stopLoss        Float?
  takeProfit      Float?
  openedAt        DateTime?
  closedAt        DateTime?
  fees            Float           @default(0)
  realizedPnl     Float?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  signal TradeSignal? @relation(fields: [signalId], references: [id], onDelete: SetNull)
  plan TradePlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  journalEntries JournalEntry[]

  @@index([userId, status, createdAt])
  @@index([assetId, createdAt])
  @@index([signalId])
  @@index([planId])
}

model Position {
  id               String         @id @default(cuid())
  userId           String
  assetId          String
  direction        TradeDirection
  status           PositionStatus @default(OPEN)
  quantity         Float
  averageEntry     Float
  stopLoss         Float?
  takeProfit       Float?
  openedAt         DateTime       @default(now())
  closedAt         DateTime?
  realizedPnl      Float?
  unrealizedPnl    Float?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId, status, openedAt])
  @@index([assetId, status])
}

model JournalEntry {
  id               String    @id @default(cuid())
  userId           String
  tradeExecutionId String?
  title            String
  notes            String
  emotions         String?
  tags             Json?
  rating           Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeExecution TradeExecution? @relation(fields: [tradeExecutionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([tradeExecutionId])
}

model CotData {
  id           String   @id @default(cuid())
  date         DateTime
  asset        String
  long         Float
  short        Float
  net          Float
  change       Float    @default(0)
  zScore       Float    @default(0)
  percentile   Float    @default(0)
  velocity     Float    @default(0)
  acceleration Float    @default(0)
  trend        String
  extreme      Boolean  @default(false)
  phase        String
  signal       String
  confidence   Float    @default(0)
  risk         String
  weeklyBias   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([asset, date])
  @@index([asset, date(sort: Desc)])
  @@index([date])
}
